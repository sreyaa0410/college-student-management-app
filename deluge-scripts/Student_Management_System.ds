	reports
	{
		list leave_requests_Report
		{
			displayName = "All Requests"
			show all rows from leave_requests    
			(
				student as "Student"
				leave_type as "Leave Type"
				from_date as "From Date"
				to_date as "To Date"
				reason as "Reason"
				status as "Status"
				submitted_at as "Submitted At"
				approved_by as "Approved By"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (leave_type == "Casual")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (leave_type == "Emergency")
				fields = [leave_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (leave_type == "Medical")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"New Formatting4"
				{
				condition = (leave_type == "Other")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#3598db;"
				}
			)
		}
		kanban leave_requests_by_leave_type
		{
			displayName = "Leave Types"
			show all rows from leave_requests    
			(
				student as "Student"
				leave_type as "Leave Type"
				from_date as "From Date"
				to_date as "To Date"
				reason as "Reason"
				status as "Status"
				submitted_at as "Submitted At"
				approved_by as "Approved By"
			)
			options
			(
	 			display field = leave_type
	 		)
		}
		list attendance_records_Report
		{
			displayName = "All Attendance Records"
			show all rows from attendance_records    
			(
				student as "Student"
				subject_1 as "Subject"
				date_1 as "Date"
				status as "Status"
				recorded_at as "Recorded At"
			)
		}
		list od_requests_Report
		{
			displayName = "All Onduty Requests"
			show all rows from od_requests    
			(
				student as "Student"
				event_name as "Event Name"
				event_date as "Event Date"
				purpose as "Purpose"
				proof_upload as "Proof Upload"
				status as "Status"
				submitted_at as "Submitted At"
				approved_by as "Approved By"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Approved")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Pending")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Rejected")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban od_requests_by_status
		{
			displayName = "Statuses"
			show all rows from od_requests    
			(
				student as "Student"
				event_name as "Event Name"
				event_date as "Event Date"
				purpose as "Purpose"
				proof_upload as "Proof Upload"
				status as "Status"
				submitted_at as "Submitted At"
				approved_by as "Approved By"
			)
			options
			(
	 			display field = status
	 		)
		}
		list students_Report
		{
			displayName = "All Students"
			show all rows from students    
			(
				student_id as "Student ID"
				name  as "Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				register_number as "Register Number"
				department as "Department"
				year_1 as "Year"
				contact_details as "Contact Details"
				email as "Email"
				date_of_birth as "Date of Birth"
			)
		}
		list student_dashboard_Report
		{
			displayName = "All Student Dashboards"
			show all rows from student_dashboard    
			(
				student as "Student"
				pending_ods as "Pending ODs"
				attendance_percentage as "Attendance Percentage"
				(
					display = total,average,min,max	
				)
				last_updated as "Last Updated"
			)
		}
		list admin_dashboard_Report
		{
			displayName = "All Admin Dashboards"
			show all rows from admin_dashboard    
			(
				rejected_requests as "Rejected Requests"
				total_students as "Total Students"
				last_updated as "Last Updated"
			)
		}
	}
	pages
	{
		page DashBoard
		{
