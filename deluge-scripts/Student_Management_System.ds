				width = medium
			)
			event_name
			(
    			type = text
				displayname = "Event Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			event_date
			(
    			type = date
				displayname = "Event Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			purpose
			(
    			type = textarea
				displayname = "Purpose"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			proof_upload
			(
    			type = url
				displayname = "Proof Upload"
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Submitted","Approved","Rejected","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			submitted_at
			(
    			type = datetime
				displayname = "Submitted At"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			approved_by
			(
    			type = text
				displayname = "Approved By"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Request Submitted","Proof Verification Pending","Request Rejected","Proof Verified","Proof Rejected","Approval Pending","Approved","OnDuty Active","OnDuty Completed","OnDuty Cancelled","Request Closed"}
			}
		}
		form student_dashboard
		{
			displayname = "Student Dashboard"
			success message = "Student Dashboard Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			student
			(
				type = list	
				displayname = "Student"
				values  = students.ID
    			displayformat = [student_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			pending_ods
			(
				type = number
				displayname = "Pending ODs"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			attendance_percentage
			(
    			type = percentage
				displayname = "Attendance Percentage"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_updated
			(
    			type = datetime
				displayname = "Last Updated"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
